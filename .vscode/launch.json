    "version": "0.2.0",
    "configurations": [
        {
            "name": "Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-n",
                "2"
            ]
        },
        {
            "name": "Sync remote",
            "type": "debugpy",
            "request": "launch",
            "module": "mgost",
            "args": [
                "-v",
                "sync"
            ],
            "cwd": "${workspaceFolder}/temp/remote_temp"
        }
    ]
}